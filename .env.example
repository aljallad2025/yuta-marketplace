# ─────────────────────────────────────────────
#  SUMU — Environment Variables
#  Copy this file to .env and fill in the values
#  cp .env.example .env
# ─────────────────────────────────────────────

# Server
NODE_ENV=production
PORT=4000

# Security — CHANGE THIS to a long random string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string

# JWT expiry (e.g. 7d, 30d, 1y)
JWT_EXPIRES_IN=7d

# Database — path to the SQLite file (relative to project root or absolute)
DB_PATH=./sumu.db

# CORS — comma-separated list of allowed origins in production
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Uploads — max file size in MB
UPLOAD_MAX_MB=10

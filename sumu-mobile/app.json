{
  "expo": {
    "name": "سومو",
    "slug": "sumu-app",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F2A47"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sumu.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F2A47"
      },
      "package": "com.sumu.app",
      "versionCode": 3,
      "targetSdkVersion": 35,
      "compileSdkVersion": 35,
      "minSdkVersion": 24,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-splash-screen",
      [
        "expo-build-properties",
        {
          "android": {
            "useLegacyPackaging": false,
            "enableShrinkResources": true,
            "enableProguardInReleaseBuilds": true,
            "extraProguardRules": "-keep class com.facebook.react.** { *; }"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "يحتاج سومو إلى موقعك لتحديد مطاعم ومتاجر قريبة منك."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "089e7984-a9f0-4c8a-a92d-0cdb2df8970c"
      }
    }
  }
}
